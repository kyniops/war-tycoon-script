local isFarming = false
local isCrateFarming = false
local isProcessing = false
local farmingConnection = nil
local crateThread = nil
local lastCrateId = nil -- Pour éviter de reprendre la même

local function isBuyButton(btn)
    local neon = btn:FindFirstChild("Neon") or btn:FindFirstChild("Button")
    if neon and neon:IsA("BasePart") then
        local color = neon.Color
        local h, s, v = color:ToHSV()
        if h > 0.25 and h < 0.45 then return true end -- Vert
        if h > 0.55 and h < 0.72 then return true end -- Bleu
        if h > 0.12 and h < 0.20 then -- Jaune (Renaissance)
             local name = string.lower(btn.Name)
             local parentName = btn.Parent and string.lower(btn.Parent.Name) or ""
             if string.find(name, "rebirth") or string.find(name, "renaissance") or 
                string.find(parentName, "rebirth") or string.find(parentName, "renaissance") then
                 return true 
             end
        end
    end
    return false
end

local function collectAndSellCrate(isFallback)
    if isProcessing then return end
    isProcessing = true
    updateStatus("Recherche Caisse...")
    updateBigTimer("") 
    
    -- Pré-check pour éviter le délai au retour
    if not FARM_CONFIG.SellPosition then storeSellPosition() end
    
    local success, err = pcall(function()
        -- RECHERCHE GLOBALE ET TOTALE (SCAN TOUTE LA MAP)
        -- On ne se limite plus à un dossier spécifique. On cherche partout.
        updateStatus("Scan complet de la map...")
        local allCrates = {}
        
        -- On scanne via les PROXIMITY PROMPT (Interaction 'E')
        -- C'est le seul moyen sûr de trouver des objets interactifs valides
        for _, prompt in ipairs(Workspace:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") then
                local part = prompt.Parent
                local model = part.Parent
                
                -- On vérifie si c'est bien une caisse (le modèle ou la part contient "Crate")
                if (part:IsA("BasePart") and (string.find(part.Name, "Crate") or (model and string.find(model.Name, "Crate")))) then
                    
                    -- On vérifie l'attribut Owner sur le modèle ou la part
                    local owner = part:GetAttribute("Owner") or (model and model:GetAttribute("Owner"))
                    
                    -- Si pas à nous, on ajoute
                    if not owner or tostring(owner) ~= plr.Name then
                         table.insert(allCrates, part)
                    end
                end
            end
        end
        
        if #allCrates > 0 then
            -- Mélange de la table pour un vrai aléatoire (Fisher-Yates Shuffle)
            for i = #allCrates, 2, -1 do
                local j = math.random(i)
                allCrates[i], allCrates[j] = allCrates[j], allCrates[i]
            end
            
            local selectedCrate = nil
            
            -- On cherche une caisse différente de la dernière
            for _, c in ipairs(allCrates) do
                if c ~= lastCrateId then
                    selectedCrate = c
                    break
                end
            end
            
            -- Si on n'a rien trouvé (ou une seule caisse dispo), on prend la première
            if not selectedCrate then selectedCrate = allCrates[1] end
            
            lastCrateId = selectedCrate
            
            if not isFallback and not isCrateFarming then return end
            
            updateStatus("Vol Caisse (Aléatoire)...")
                local root = getRoot()
                
                if selectedCrate and selectedCrate.CFrame then
                    -- TP simple à côté de la caisse
                    -- Plus aucun blocage ni fantôme
                    root.CFrame = selectedCrate.CFrame * CFrame.new(3, 1, 0)
                else
                    return
                end
                
                task.wait(0.2) -- Délai infime avant d'appuyer (0.2s)
                
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                
                -- TEMPS DE CAPTURE FIXE ET RAPIDE
                -- On attend juste le temps nécessaire pour remplir la barre (5.5s environ)
                -- Dès que c'est fini, on part INSTANTANÉMENT
                task.wait(5.5) 
                
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                
                -- === INSTANT TP RETOUR ===
                if FARM_CONFIG.SafePosition then
                    updateStatus("Zone Sûre (Cooldown)")
                    root.CFrame = FARM_CONFIG.SafePosition
                    root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    root.AssemblyAngularVelocity = Vector3.new(0,0,0)
                    
                    -- TIMER OVERLAY
                    for i = 12, 1, -1 do
                        if not isCrateFarming then break end
                        updateBigTimer(tostring(i)) 
                        updateStatus("Sécurité: " .. i .. "s")
                        task.wait(1)
                    end
                    updateBigTimer("")
                    
                    if not isCrateFarming then return end
                    
                    updateStatus("Vente...")
                    root.CFrame = FARM_CONFIG.SellPosition
                    root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    root.AssemblyAngularVelocity = Vector3.new(0,0,0)
                    
                    task.wait(1)
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                    task.wait(FARM_CONFIG.SellCrate)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                    task.wait(1.5)
                else
                    updateStatus("Err: Pas de Base")
                    task.wait(2)
                end
            else
                updateStatus("Aucune caisse")
                task.wait(1)
            end
        else
            updateStatus("Err: Système Caisses")
        end
    end)
    
    if not success then
        warn("Erreur CrateFarm:", err)
        updateStatus("Erreur interne")
        task.wait(2)
    end
    
    isProcessing = false
    if isCrateFarming then updateStatus("En attente...") else updateStatus("Arrêté") end
end

local function stopAll()
    isFarming = false
    isCrateFarming = false
    isProcessing = false 
    updateStatus("Arrêté")
    updateBigTimer("")
    
    if farmingConnection then farmingConnection:Disconnect() farmingConnection = nil end
    if crateThread then task.cancel(crateThread) crateThread = nil end
end

local function startAutoFarm()
    if isFarming then return end
    stopAll() 
    isFarming = true
    updateStatus("AutoBuy Actif")
    
    local blacklist = {}
    local lastTarget = nil
    local lastTargetTime = 0
    local lastCashCollectTime = 0
    local isCollectingCash = false 
    
    farmingConnection = RunService.Heartbeat:Connect(function()
        if not ScreenGui or not ScreenGui.Parent then stopAll() return end
        if not isFarming then 
            if farmingConnection then farmingConnection:Disconnect() farmingConnection = nil end 
            return 
        end
        if isProcessing or isCollectingCash then return end 
        
        local currentMoney = getCurrentCash()
        local tycoon = findPlayerTycoon()
        local now = tick()
        
        if now - lastCashCollectTime > FARM_CONFIG.CashCollectInterval then
            if tycoon then
                local giver = findCashGiver(tycoon)
                if giver then
                    isCollectingCash = true 
                    updateStatus("Collecte Argent...")
                    getRoot().CFrame = giver.CFrame * CFrame.new(4, 2, 0)
                    task.wait(0.2)
                    if firetouchinterest then
                        firetouchinterest(getRoot(), giver, 0)
                        task.wait()
                        firetouchinterest(getRoot(), giver, 1)
                    else
                        local oldPos = getRoot().CFrame
                        getRoot().CFrame = giver.CFrame 
                        task.wait(0.1)
                        getRoot().CFrame = oldPos 
                    end
                    task.wait(0.5)
                    lastCashCollectTime = now 
                    isCollectingCash = false
                    return 
                end
            end
            lastCashCollectTime = now 
        end
        
        for btn, _ in pairs(blacklist) do if not btn.Parent then blacklist[btn] = nil end end
        
        local buttons = tycoon and tycoon:FindFirstChild("UnpurchasedButtons")
        if currentMoney >= FARM_CONFIG.CashTarget and buttons then
            local targetButton = nil
            for _, btn in ipairs(buttons:GetChildren()) do
                if blacklist[btn] then continue end 
                if isBuyButton(btn) then targetButton = btn break end
            end
            
            if targetButton then
                updateStatus("Achat: " .. targetButton.Name)
                if targetButton == lastTarget then
                    if now - lastTargetTime > FARM_CONFIG.BlacklistTimeout then
                        blacklist[targetButton] = true
                        lastTarget = nil
                        return
                    end
                else
                    lastTarget = targetButton
                    lastTargetTime = now
                end
                
                local neon = targetButton:FindFirstChild("Neon") or targetButton:FindFirstChild("Button")
                if neon then
                    getRoot().CFrame = neon.CFrame + Vector3.new(0, 5, 0)
                    task.wait(FARM_CONFIG.TeleportDelay)
                end
            else
                lastTarget = nil
                updateStatus("Recherche...")
            end
        else
            updateStatus("Pas d'argent / Pas de bouton")
        end
    end)
end

local function startCrateFarm()
    if isCrateFarming then return end
    stopAll() 
    isCrateFarming = true
    isProcessing = false 
    storeSellPosition()
    updateStatus("Vol Caisses Actif")
    
    crateThread = task.spawn(function()
        while isCrateFarming do
            if not ScreenGui or not ScreenGui.Parent then isCrateFarming = false break end
            collectAndSellCrate(false)
            task.wait(1)
        end
        crateThread = nil
    end)
end

