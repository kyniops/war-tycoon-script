local function isBuyButton(btn)
    local neon = btn:FindFirstChild("Neon") or btn:FindFirstChild("Button")
    if neon and neon:IsA("BasePart") then
        -- Check si c'est une récompense quotidienne (Bloqué)
        local billboard = btn:FindFirstChild("BillboardGui") or btn:FindFirstChildOfClass("BillboardGui")
        if billboard then
            for _, text in pairs(billboard:GetDescendants()) do
                if text:IsA("TextLabel") then
                    local content = string.lower(text.Text)
                    if string.find(content, "daily") or string.find(content, "jour") or string.find(content, "reward") or string.find(content, "recompense") then
                        return false -- On ignore les récompenses quotidiennes
                    end
                end
            end
        end

        local color = neon.Color
        local h, s, v = color:ToHSV()
        
        -- Vert (Classique)
        if h > 0.25 and h < 0.45 then return true end 
        -- Bleu (Rebirth/Spécial)
        if h > 0.55 and h < 0.72 then return true end 
        -- Cyan / Bleu Ciel (Véhicules & Améliorations) - NOUVEAU
        if h > 0.45 and h < 0.55 then return true end
        
        -- Jaune (Renaissance)
        if h > 0.12 and h < 0.20 then 
             local name = string.lower(btn.Name)
             local parentName = btn.Parent and string.lower(btn.Parent.Name) or ""
             if string.find(name, "rebirth") or string.find(name, "renaissance") or 
                string.find(parentName, "rebirth") or string.find(parentName, "renaissance") then
                 return true 
             end
        end
    end
    return false
end

