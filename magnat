local function getRoot()
    local char = plr.Character or plr.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

local function getCurrentCash()
    local stats = plr:FindFirstChild("leaderstats")
    local cash = stats and stats:FindFirstChild("Cash")
    return cash and cash.Value or 0
end

local function updateStatus(text)
    if StatusLabel then StatusLabel.Text = text end
end

local function updateBigTimer(text)
    if BigTimerLabel then BigTimerLabel.Text = text end
end

local function findPlayerTycoon()
    local tycoons = Workspace:FindFirstChild("Tycoon") and Workspace.Tycoon:FindFirstChild("Tycoons")
    if not tycoons then tycoons = Workspace:FindFirstChild("Tycoons") end
    
    if tycoons then
        for _, tycoon in ipairs(tycoons:GetChildren()) do
            if (tycoon:FindFirstChild("Owner") and tycoon.Owner.Value == plr) or
               (tycoon:FindFirstChild("Owner") and tycoon.Owner:IsA("ObjectValue") and tycoon.Owner.Value == plr) or
               (tycoon:FindFirstChild("Owner") and tycoon.Owner:IsA("StringValue") and tycoon.Owner.Value == plr.Name) then
                return tycoon
            end
        end
    end
    return nil
end

local function findCashGiver(tycoon)
    local essentials = tycoon:FindFirstChild("Essentials")
    if not essentials then return nil end
    
    local collectorParts = essentials:FindFirstChild("CollectorParts")
    if collectorParts then
        local exactCollector = collectorParts:FindFirstChild("Collector")
        if exactCollector and exactCollector:IsA("BasePart") then return exactCollector end
    end
    
    local candidates = {}
    for _, descendant in ipairs(essentials:GetDescendants()) do
         if descendant:IsA("BasePart") and descendant.Name == "Collector" then
             local col = descendant.Color
             if col.G > 0.9 and col.R < 0.1 and col.B < 0.1 then
                 table.insert(candidates, descendant)
             end
         end
    end
    
    local bestGiver = nil
    local bestY = -99999
    for _, cand in ipairs(candidates) do
        if cand.Position.Y > bestY then
            bestY = cand.Position.Y
            bestGiver = cand
        end
    end
    return bestGiver
end

local function storeSellPosition()
    local tycoon = findPlayerTycoon()
    if not tycoon then return false end
    
    local essentials = tycoon:FindFirstChild("Essentials")
    if essentials then
        for _, desc in ipairs(essentials:GetDescendants()) do
            if desc.Name == "Plane" and desc.Parent.Name == "Collector" then
                FARM_CONFIG.SellPosition = desc.CFrame * CFrame.new(0, 3, 0)
                -- Pré-calcul de la position Safe
                FARM_CONFIG.SafePosition = FARM_CONFIG.SellPosition * CFrame.new(40, 0, 0)
                return true
            end
        end
    end
    return false
end

