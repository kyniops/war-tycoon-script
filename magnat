local function refreshPlayerList()
    if not PlayerPopup.Visible then return end
    
    for _, c in pairs(PlayerPopup:GetChildren()) do
        if c:IsA("TextButton") or c:IsA("TextLabel") then c:Destroy() end
    end
    
    -- Titre
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(0.9, 0, 0, 20)
    title.BackgroundTransparency = 1
    title.Text = "CIBLER JOUEUR"
    title.TextColor3 = UI_CONFIG.Colors.Text
    title.Font = Enum.Font.GothamBold
    title.TextSize = 12
    title.Parent = PlayerPopup
    
    -- Bouton "TOUS / RESET"
    local btnAll = Instance.new("TextButton")
    btnAll.Size = UDim2.new(0.9, 0, 0, 30)
    btnAll.BackgroundColor3 = FARM_CONFIG.TargetPlayer == nil and UI_CONFIG.Colors.ButtonOn or UI_CONFIG.Colors.ButtonOff
    btnAll.Text = "TOUS (Reset)"
    btnAll.TextColor3 = FARM_CONFIG.TargetPlayer == nil and UI_CONFIG.Colors.TextOn or UI_CONFIG.Colors.Text
    btnAll.Font = Enum.Font.GothamSemibold
    btnAll.TextSize = 12
    btnAll.Parent = PlayerPopup
    
    local cAll = Instance.new("UICorner")
    cAll.CornerRadius = UDim.new(0, 6)
    cAll.Parent = btnAll
    
    btnAll.MouseButton1Click:Connect(function()
        FARM_CONFIG.TargetPlayer = nil
        updateStatus("Cible: TOUS")
        btnTarget.Text = "🎯"
        refreshPlayerList() -- Refresh pour mettre à jour les couleurs
    end)
    
    -- Bouton ACTUALISER
    local btnRefresh = Instance.new("TextButton")
    btnRefresh.Size = UDim2.new(0.9, 0, 0, 30)
    btnRefresh.BackgroundColor3 = Color3.fromRGB(52, 152, 219) -- Bleu
    btnRefresh.Text = "🔄 Actualiser"
    btnRefresh.TextColor3 = Color3.fromRGB(255, 255, 255)
    btnRefresh.Font = Enum.Font.GothamBold
    btnRefresh.TextSize = 11
    btnRefresh.Parent = PlayerPopup
    
    local cRefresh = Instance.new("UICorner")
    cRefresh.CornerRadius = UDim.new(0, 6)
    cRefresh.Parent = btnRefresh
    
    btnRefresh.MouseButton1Click:Connect(function()
        refreshPlayerList()
    end)

    -- Scan des joueurs et caisses (UNIQUEMENT CHARGÉS)
    local playersData = {}
    local crateCounts = {}
    
    -- On scanne d'abord les caisses réellement présentes dans le Workspace
    local crates = Workspace:FindFirstChild("Crate Workspace", true) or (Workspace:FindFirstChild("Game Systems") and Workspace["Game Systems"]:FindFirstChild("Crate Workspace"))
    if crates then
        for _, crate in ipairs(crates:GetChildren()) do
            if crate:IsA("BasePart") then
                local o = crate:GetAttribute("Owner")
                if o then
                    local sOwner = tostring(o)
                    crateCounts[sOwner] = (crateCounts[sOwner] or 0) + 1
                end
            end
        end
    end
    
    -- On ne liste que les joueurs qui ont au moins 1 caisse chargée
    for name, count in pairs(crateCounts) do
        if name ~= plr.Name then
            local p = Players:FindFirstChild(name)
            local teamName = "Unknown"
            if p and p.Team then
                teamName = p.Team.Name
            end

            table.insert(playersData, {
                Name = name,
                Team = teamName,
                Count = count
            })
        end
    end
    
    table.sort(playersData, function(a,b) 
        if a.Count ~= b.Count then return a.Count > b.Count end
        return a.Name < b.Name
    end)

    if #playersData == 0 then
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.9, 0, 0, 25)
        lbl.BackgroundTransparency = 1
        lbl.Text = "Aucune caisse visible"
        lbl.TextColor3 = Color3.fromRGB(150, 150, 150)
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 11
        lbl.Parent = PlayerPopup
    else
        for _, data in ipairs(playersData) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(0.9, 0, 0, 30)
            -- Highlight si sélectionné
            local isSelected = (FARM_CONFIG.TargetPlayer == data.Name)
            
            if isSelected then
                btn.BackgroundColor3 = Color3.fromRGB(60, 60, 70) -- Même couleur que les boutons d'action (Gris foncé)
                btn.BackgroundTransparency = 0 -- Opaque, simple
            else
                btn.BackgroundColor3 = UI_CONFIG.Colors.ButtonOff
                btn.BackgroundTransparency = 0
            end
            
            -- Affichage: Pseudo [TEAM] [Nbr Caisses]
            -- Team en MAJUSCULE, entre crochets, plus gros, blanc
            local teamStr = string.upper(data.Team)
            local text = data.Name .. " <font color='rgb(255,255,255)' size='14'>[" .. teamStr .. "]</font> [" .. data.Count .. " 📦]"
            
            btn.RichText = true
            btn.TextColor3 = Color3.fromRGB(255, 200, 100) -- Orange car caisses présentes
            btn.Text = text
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 11
            btn.Parent = PlayerPopup
            
            local c = Instance.new("UICorner")
            c.CornerRadius = UDim.new(0, 6)
            c.Parent = btn
            
            btn.MouseButton1Click:Connect(function()
                FARM_CONFIG.TargetPlayer = data.Name
                updateStatus("Cible: " .. data.Name)
                btnTarget.Text = "🎯 " .. string.sub(data.Name, 1, 3)
                refreshPlayerList()
            end)
        end
    end
    
    PlayerPopup.CanvasSize = UDim2.new(0, 0, 0, (#playersData + 3) * 35 + 20)
end

