-- 🚀 MOTEUR D'AUTOFARM
-- ==============================================================================
local ScreenGui -- Référence globale pour vérifier l'existence
local StatusLabel -- Référence pour le label de statut

local function updateStatus(text)
    if StatusLabel then
        StatusLabel.Text = "Statut: " .. text
    end
end

local function collectAndSellCrate(isFallback)
    if isProcessing then return end
    isProcessing = true
    updateStatus("Recherche Caisse...")
    
    local crates = Workspace:FindFirstChild("Game Systems") and Workspace["Game Systems"]:FindFirstChild("Crate Workspace")
    
    if crates then
        -- On récupère toutes les caisses disponibles dans une liste
        local availableCrates = {}
        for _, crate in ipairs(crates:GetChildren()) do
            if crate.Name:find("Crate") and crate:IsA("BasePart") then
                local owner = crate:GetAttribute("Owner")
                if not owner or tostring(owner) ~= plr.Name then
                     table.insert(availableCrates, crate)
                end
            end
        end
        
        -- Si on a des caisses, on en choisit une AU HASARD
        if #availableCrates > 0 then
            -- Mélange un peu pour éviter de prendre toujours la même si le random est faible
            local randomIndex = math.random(1, #availableCrates)
            local crate = availableCrates[randomIndex]
            
            -- Vérification d'arrêt
            if isFallback then
                if not isFarming then return end
            else
                if not isCrateFarming then return end
            end
            
            updateStatus("Vol Caisse (Aléatoire)...")
            local root = getRoot()
            root.CFrame = crate.CFrame * CFrame.new(3, 0, 0)
            task.wait(2)
            
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(FARM_CONFIG.RecupCrate)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
            
            task.wait(2)
            
            if not FARM_CONFIG.SellPosition then storeSellPosition() end
            if FARM_CONFIG.SellPosition then
                updateStatus("Vente Caisse...")
                root.CFrame = FARM_CONFIG.SellPosition
                task.wait(2)
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                task.wait(FARM_CONFIG.SellCrate)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                task.wait(2)
            end
        end
    end
    isProcessing = false
    updateStatus("En attente...")
end

local function stopAll()
    isFarming = false
    isCrateFarming = false
    isProcessing = false -- CORRECTION CRITIQUE : Débloquer l'état
    updateStatus("Arrêté")
    
    if farmingConnection then 
        farmingConnection:Disconnect() 
        farmingConnection = nil 
    end
    if crateThread then 
        task.cancel(crateThread) -- Force l'arrêt immédiat
        crateThread = nil 
    end
end

local function showBigMessage(text)
    -- Création du ScreenGui temporaire
    local msgGui = Instance.new("ScreenGui")
    msgGui.Name = "BigMessageGUI"
    msgGui.Parent = game.CoreGui
    msgGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    
    local label = Instance.new("TextLabel")
    label.Name = "Message"
    label.Size = UDim2.new(1, 0, 0, 100)
    label.Position = UDim2.new(0, 0, 0.4, 0) -- Milieu de l'écran
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255, 255, 255) -- Blanc
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0) -- Bordure Noire
    label.TextStrokeTransparency = 0 -- Bordure opaque (très visible)
    label.Font = Enum.Font.FredokaOne -- Police grasse et impactante
    label.TextSize = 60
    label.Parent = msgGui
    
    -- Animation d'apparition/disparition
    task.spawn(function()
        -- Effet de zoom in
        for i = 0, 1, 0.1 do
            label.TextTransparency = 1 - i
            label.TextStrokeTransparency = 1 - i
            task.wait(0.03)
        end
        
        task.wait(2) -- Reste affiché 2 secondes
        
        -- Effet de zoom out
        for i = 0, 1, 0.1 do
            label.TextTransparency = i
            label.TextStrokeTransparency = i
            task.wait(0.03)
        end
        
        msgGui:Destroy()
    end)
end

local function startAutoFarm()
    if isFarming then return end
    stopAll() -- Arrête tout le reste
    isFarming = true
    updateStatus("Démarrage AutoBuy...")
    showBigMessage("Amadou Pro Tool is better") -- Message personnalisé
    
    local blacklist = {}
    local lastTarget = nil
    local lastTargetTime = 0
    local lastCashCollectTime = 0
    local isCollectingCash = false -- Flag pour éviter le spam
    
    farmingConnection = RunService.Heartbeat:Connect(function()
        -- 1. Sécurité GUI
        if not ScreenGui or not ScreenGui.Parent then
            stopAll()
            return
        end
        
        -- 2. Sécurité État
        if not isFarming then
            if farmingConnection then farmingConnection:Disconnect() farmingConnection = nil end
            return
        end
        
        if isProcessing or isCollectingCash then return end -- Ne pas interrompre une action critique
        
        local currentMoney = getCurrentCash()
        local tycoon = findPlayerTycoon()
        local now = tick()
        
        -- 3. Collecte d'Argent (Toutes les 10s)
        if now - lastCashCollectTime > FARM_CONFIG.CashCollectInterval then
            if tycoon then
                local giver = findCashGiver(tycoon)
                if giver then
                    isCollectingCash = true -- Bloque les autres actions
                    updateStatus("Collecte Argent...")
                    
                    getRoot().CFrame = giver.CFrame + Vector3.new(0, 3, 0)
                    task.wait(0.2)
                    getRoot().CFrame = giver.CFrame -- Dedans
                    
                    if firetouchinterest then
                        firetouchinterest(getRoot(), giver, 0)
                        task.wait()
                        firetouchinterest(getRoot(), giver, 1)
                    end
                    
                    task.wait(0.5)
                    lastCashCollectTime = now -- Reset APRÈS la collecte réussie
                    isCollectingCash = false
                    return -- Retour au prochain tick
                end
            end
            lastCashCollectTime = now -- Reset si pas trouvé
        end
        
        -- 4. Nettoyage Blacklist (Instances disparues uniquement)
        for btn, _ in pairs(blacklist) do
            if not btn.Parent then blacklist[btn] = nil end
        end
        
        -- 5. Logique d'Achat
        local buttons = tycoon and tycoon:FindFirstChild("UnpurchasedButtons")
        
        if currentMoney >= FARM_CONFIG.CashTarget and buttons then
            local targetButton = nil
            
            for _, btn in ipairs(buttons:GetChildren()) do
                if blacklist[btn] then continue end -- Ignorer boutons bloqués
                
                if isBuyButton(btn) then
                    targetButton = btn
                    break -- On prend le premier valide
                end
            end
            
            if targetButton then
                updateStatus("Achat: " .. targetButton.Name)
                -- Gestion du blocage
                if targetButton == lastTarget then
                    if now - lastTargetTime > FARM_CONFIG.BlacklistTimeout then
                        -- Bloqué > 5s -> Blacklist Permanente
                        blacklist[targetButton] = true
                        lastTarget = nil
                        updateStatus("Bloqué -> Blacklist: " .. targetButton.Name)
                        return
                    end
                else
                    lastTarget = targetButton
                    lastTargetTime = now
                end
                
                local neon = targetButton:FindFirstChild("Neon") or targetButton:FindFirstChild("Button")
                if neon then
                    getRoot().CFrame = neon.CFrame + Vector3.new(0, 5, 0)
                    task.wait(FARM_CONFIG.TeleportDelay)
                end
            else
                lastTarget = nil
                updateStatus("Recherche bouton...")
            end
        else
            updateStatus("Pas assez d'argent / Pas de bouton")
        end
    end)
end

local function startCrateFarm()
    if isCrateFarming then return end
    stopAll() -- Arrête tout le reste
    isCrateFarming = true
    storeSellPosition()
    updateStatus("Démarrage Vol Caisses...")
    
    crateThread = task.spawn(function()
        while isCrateFarming do
            if not ScreenGui or not ScreenGui.Parent then
                isCrateFarming = false
                break
            end
            collectAndSellCrate(false)
            task.wait(1)
        end
        crateThread = nil
    end)
end

