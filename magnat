-- Boucle de mise à jour de la Localisation
task.spawn(function()
    while ScreenGui and ScreenGui.Parent do
        local myRoot = getRoot()
        if myRoot then
            local closest = "Nature"
            local minDist = 400 -- Rayon de détection large
            
            -- Recherche des Tycoons
            local tycoons = Workspace:FindFirstChild("Tycoon") and Workspace.Tycoon:FindFirstChild("Tycoons")
            if not tycoons then tycoons = Workspace:FindFirstChild("Tycoons") end
            
            if tycoons then
                for _, t in ipairs(tycoons:GetChildren()) do
                    -- On utilise GetPivot pour être sûr
                    local tRoot = t:FindFirstChild("Essentials") and t.Essentials:FindFirstChild("Spawn") 
                    if not tRoot then tRoot = t:GetPivot().Position end
                    
                    local pos = (typeof(tRoot) == "Instance") and tRoot.Position or tRoot
                    local dist = (pos - myRoot.Position).Magnitude
                    
                    if dist < minDist then
                        closest = t.Name
                        minDist = dist
                    end
                end
            end
            
            if btnAutoCrate then
                 -- Mise à jour du texte du bouton Vol Caisses avec la localisation
                 if isCrateFarming then
                     btnAutoCrate.Text = "Vol Caisses: ON (" .. closest .. ")"
                 else
                     -- Si désactivé, on garde juste OFF
                     btnAutoCrate.Text = "Vol Caisses: OFF"
                 end
            end
        end
        task.wait(0.5)
    end
end)

