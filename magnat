local function refreshBlacklistPopup()
    if not BLPopup.Visible then return end
    
    -- Refresh liste
    for _, c in pairs(BLPopup:GetChildren()) do
        if c:IsA("TextLabel") then c:Destroy() end
    end
    
    local count = 0
    if _G.AmadouBlacklistNames then
        -- Tri alphabétique pour plus de clarté
        local names = {}
        for name, _ in pairs(_G.AmadouBlacklistNames) do
            table.insert(names, name)
        end
        table.sort(names)
        
        for _, name in ipairs(names) do
            count = count + 1
            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(0.9, 0, 0, 25)
            lbl.BackgroundTransparency = 1
            lbl.Text = name
            lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 11
            lbl.Parent = BLPopup
        end
    end
    
    if count == 0 then
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.9, 0, 0, 25)
        lbl.BackgroundTransparency = 1
        lbl.Text = "Aucun item bloqué"
        lbl.TextColor3 = Color3.fromRGB(100, 100, 100)
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 11
        lbl.Parent = BLPopup
    end
    BLPopup.CanvasSize = UDim2.new(0, 0, 0, count * 30 + 20)
end

