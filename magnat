local BLACKLIST_FILE = "amadou_blacklist.json"

-- Initialisation de la table globale (Noms des boutons - Strings)
if not _G.AmadouBlacklistNames then _G.AmadouBlacklistNames = {} end

local function saveBlacklist()
    -- On vérifie si l'exécuteur supporte l'écriture de fichier
    if writefile then
        local success, err = pcall(function()
            local json = HttpService:JSONEncode(_G.AmadouBlacklistNames)
            writefile(BLACKLIST_FILE, json)
        end)
        if not success then warn("Erreur Sauvegarde Blacklist:", err) end
    end
end

local function loadBlacklist()
    -- On vérifie si le fichier existe et si on peut le lire
    if readfile and isfile and isfile(BLACKLIST_FILE) then
        local success, err = pcall(function()
            local json = readfile(BLACKLIST_FILE)
            local data = HttpService:JSONDecode(json)
            if data and type(data) == "table" then
                _G.AmadouBlacklistNames = data
            end
        end)
        if not success then warn("Erreur Chargement Blacklist:", err) end
    end
end

-- Charger au démarrage du script
loadBlacklist()

