-- ==============================================================================
-- 🛠️ FONCTIONS UTILITAIRES
-- ==============================================================================
local function getRoot()
    local char = plr.Character or plr.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

local function getCurrentCash()
    local stats = plr:FindFirstChild("leaderstats")
    local cash = stats and stats:FindFirstChild("Cash")
    return cash and cash.Value or 0
end

local function findPlayerTycoon()
    local tycoons = Workspace:FindFirstChild("Tycoon") and Workspace.Tycoon:FindFirstChild("Tycoons")
    if not tycoons then tycoons = Workspace:FindFirstChild("Tycoons") end
    
    if tycoons then
        for _, tycoon in ipairs(tycoons:GetChildren()) do
            if (tycoon:FindFirstChild("Owner") and tycoon.Owner.Value == plr) or
               (tycoon:FindFirstChild("Owner") and tycoon.Owner:IsA("ObjectValue") and tycoon.Owner.Value == plr) or
               (tycoon:FindFirstChild("Owner") and tycoon.Owner:IsA("StringValue") and tycoon.Owner.Value == plr.Name) then
                return tycoon
            end
        end
    end
    return nil
end

local function findCashGiver(tycoon)
    local essentials = tycoon:FindFirstChild("Essentials")
    if not essentials then return nil end
    
    -- Recherche intelligente du collecteur
    for _, descendant in ipairs(essentials:GetDescendants()) do
         if descendant:IsA("BasePart") then
             local name = string.lower(descendant.Name)
             
             -- 1. Par Nom
             if name == "collector" or name == "giver" or name == "cashcollector" then
                 -- Vérification supplémentaire par couleur (Vert pur) si le nom est générique
                 if name == "collector" then
                     local col = descendant.Color
                     if col.G > 0.9 and col.R < 0.1 and col.B < 0.1 then
                         return descendant
                     end
                 else
                     return descendant
                 end
             end
             
             -- 2. Fallback par Couleur (Vert pur) si le nom n'est pas standard
             local col = descendant.Color
             if col.G > 0.8 and col.R < 0.2 and col.B < 0.2 then
                 -- On vérifie que ce n'est pas un bouton d'achat
                 if not descendant.Parent:FindFirstChild("Button") then
                      return descendant
                 end
             end
         end
    end
    return nil
end

local function storeSellPosition()
    local tycoon = findPlayerTycoon()
    if not tycoon then return false end
    
    local essentials = tycoon:FindFirstChild("Essentials")
    if essentials then
        -- Cherche le collecteur d'huile pour la vente des caisses
        for _, desc in ipairs(essentials:GetDescendants()) do
            if desc.Name == "Plane" and desc.Parent.Name == "Collector" then
                FARM_CONFIG.SellPosition = desc.CFrame * CFrame.new(0, 3, 0)
                return true
            end
        end
    end
    return false
end

-- ==============================================================================
-- 🧠 LOGIQUE D'ANALYSE DES BOUTONS (FILTRE ROBUX)
-- ==============================================================================
local function isBuyButton(btn)
    local neon = btn:FindFirstChild("Neon") or btn:FindFirstChild("Button")
    if neon and neon:IsA("BasePart") then
        local color = neon.Color
        local h, s, v = color:ToHSV()
        
        -- 1. VERT (Classique)
        if h > 0.25 and h < 0.45 then return true end
        
        -- 2. BLEU (Véhicules)
        if h > 0.55 and h < 0.72 then return true end
        
        -- 3. JAUNE (Renaissance UNIQUEMENT)
        if h > 0.12 and h < 0.20 then
             local name = string.lower(btn.Name)
             local parentName = btn.Parent and string.lower(btn.Parent.Name) or ""
             
             if string.find(name, "rebirth") or string.find(name, "renaissance") or 
                string.find(parentName, "rebirth") or string.find(parentName, "renaissance") then
                 return true 
             end
        end
    end
    return false
end

