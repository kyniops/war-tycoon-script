local ORDERED_TEAMS = {
    "Alpha", "Bravo", "Charlie", "Delta", "Echo", "Foxtrot", "Golf", "Hotel", 
    "India", "Juliet", "Kilo", "Lima", "Mike", "November", "Oscar", "Papa", 
    "Quebec", "Romeo", "Sierra", "Tango", "Uniform", "Victor", "Whiskey", 
    "X-ray", "Yankee", "Zulu"
}

local FARM_STATE = {
    LastBase = nil, -- Nom de la dernière base visitée/volée
    Direction = 1,  -- 1: Droite (Suivant), -1: Gauche (Précédent)
    CurrentIndex = 1
}

local function getTycoonPosition(name)
    local tycoons = Workspace:FindFirstChild("Tycoon") and Workspace.Tycoon:FindFirstChild("Tycoons")
    if not tycoons then tycoons = Workspace:FindFirstChild("Tycoons") end
    
    if tycoons then
        local t = tycoons:FindFirstChild(name)
        if t then
            -- On cherche un point de spawn ou le pivot pour atterrir AU SOL
            local essentials = t:FindFirstChild("Essentials")
            if essentials then
                -- Priorité 1: Le Spawn Pad (Généralement au sol, à l'entrée)
                local spawn = essentials:FindFirstChild("Spawn")
                if spawn and spawn:IsA("BasePart") then return spawn.CFrame end
                
                -- Priorité 2: Le Panneau Owner (Devant la base)
                local ownerSign = essentials:FindFirstChild("Owner")
                if ownerSign and ownerSign:IsA("BasePart") then return ownerSign.CFrame end
            end
            -- Fallback: Pivot du modèle (souvent au centre, parfois en l'air)
            return t:GetPivot()
        end
    end
    return nil
end

local function getSafeScoutPosition(name)
    local tycoons = Workspace:FindFirstChild("Tycoon") and Workspace.Tycoon:FindFirstChild("Tycoons")
    if not tycoons then tycoons = Workspace:FindFirstChild("Tycoons") end
    
    if tycoons then
        local t = tycoons:FindFirstChild(name)
        if t then
            local pivotCf = t:GetPivot()
            local center = pivotCf.Position
            
            -- Stratégie 1: Géométrique (Spawn -> Centre -> Arrière)
            -- Le Spawn est toujours à l'entrée (Devant).
            local essentials = t:FindFirstChild("Essentials")
            local spawn = essentials and essentials:FindFirstChild("Spawn")
            
            if spawn and spawn:IsA("BasePart") then
                local front = spawn.Position
                local vecToBack = (center - front) -- Vecteur qui traverse la base vers l'arrière
                local dir = vecToBack.Unit
                
                -- On ajoute 130 studs depuis le centre pour être bien derrière les murs
                return CFrame.new(center + dir * 130)
            end
            
            -- Stratégie 2: Fallback Local Space (Arrière du modèle)
            -- En Roblox, +Z est l'arrière (Back), -Z est l'avant (LookVector).
            -- On recule de 130 studs.
            return pivotCf * CFrame.new(0, 0, 130)
        end
    end
    return nil
end

local function getMyTeamIndex()
    local myTycoon = findPlayerTycoon()
    if myTycoon then
        for i, name in ipairs(ORDERED_TEAMS) do
            if name == myTycoon.Name then return i end
        end
    end
    return 1 -- Par défaut
end

local function collectAndSellCrate(isFallback)
    if isProcessing then return end
    isProcessing = true
    updateBigTimer("") 
    
    -- Pré-check pour éviter le délai au retour
    if not FARM_CONFIG.SellPosition then storeSellPosition() end
    
    local success, err = pcall(function()
        
        -- === ÉTAPE 0: RETOUR À LA DERNIÈRE BASE (POUR SCANNER) ===
        -- Uniquement si on est en mode "Tour de Map" (Pas de cible manuelle)
        if not FARM_CONFIG.TargetPlayer and FARM_STATE.LastBase then
            updateStatus("Retour: " .. FARM_STATE.LastBase)
            local lastPos = getSafeScoutPosition(FARM_STATE.LastBase) -- Use SafeScoutPosition instead of getTycoonPosition
                if lastPos then
                    local root = getRoot()
                    
                    -- On y va pour charger les chunks voisins
                    if plr then plr:RequestStreamAroundAsync(lastPos.Position, 0.5) end
                    root.CFrame = lastPos + Vector3.new(0, 3, 0) -- Plus bas pour être au sol
                    root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    root.AssemblyAngularVelocity = Vector3.new(0,0,0)
                    
                    task.wait(2) -- Temps pour charger la map et les entités
                end
        end

        -- === ÉTAPE 1: SCAN DES CAISSES ===
        updateStatus("Analyse Map...")
        local crates = nil
        local attempts = 0
        
        while attempts < 3 do
            local gameSystems = Workspace:FindFirstChild("Game Systems")
            if gameSystems then
                crates = gameSystems:FindFirstChild("Crate Workspace")
                if crates then break end
            end
            attempts = attempts + 1
            task.wait(0.2)
        end
        
        if not crates then crates = Workspace:FindFirstChild("Crate Workspace", true) end
        
        if crates then
            local availableCrates = {}
            local teamsWithCrates = {} -- Map: TeamName -> Bool
            
            for _, crate in ipairs(crates:GetChildren()) do
                if crate.Name:find("Crate") and crate:IsA("BasePart") then
                    local owner = crate:GetAttribute("Owner")
                    -- On exclut nos propres caisses
                    if not owner or tostring(owner) ~= plr.Name then
                         table.insert(availableCrates, crate)
                         
                         -- Identification de la Team propriétaire
                         local p = Players:FindFirstChild(tostring(owner))
                         if p and p.Team then
                             teamsWithCrates[p.Team.Name] = true
                         end
                    end
                end
            end
            
            -- Si aucune caisse, on attend
            if #availableCrates == 0 then
                 updateStatus("Aucune caisse...")
                 task.wait(2)
                 return
            end
            
            -- === ÉTAPE 2: SÉLECTION DE LA CIBLE ===
            local targetCrate = nil
            
            if FARM_CONFIG.TargetPlayer then
                -- MODE MANUEL (Cible unique)
                for _, crate in ipairs(availableCrates) do
                    local owner = crate:GetAttribute("Owner")
                    if owner and tostring(owner) == FARM_CONFIG.TargetPlayer then
                        targetCrate = crate
                        break
                    end
                end
                if not targetCrate then
                    updateStatus("Cible vide: " .. FARM_CONFIG.TargetPlayer)
                    task.wait(1)
                    return
                end
            else
                -- MODE TOUR DE MAP (Séquentiel - Sticky Direction)
                
                -- 1. Sync Index
                local currentIndex = 1
                if FARM_STATE.LastBase then
                    for i, v in ipairs(ORDERED_TEAMS) do
                        if v == FARM_STATE.LastBase then
                            currentIndex = i
                            break
                        end
                    end
                else
                    currentIndex = getMyTeamIndex()
                end
                
                -- Helper Scan Function
                local function findInDirection(startIdx, dir, checkFn)
                    local i = startIdx + dir
                    while i >= 1 and i <= #ORDERED_TEAMS do
                        local teamName = ORDERED_TEAMS[i]
                        if checkFn(teamName) then return teamName end
                        i = i + dir
                    end
                    return nil
                end
                
                -- Check Function: Has Crates?
                local function hasCrates(name)
                    return teamsWithCrates[name] == true
                end
                
                -- Check Function: Exists physically?
                local function exists(name)
                    return getTycoonPosition(name) ~= nil
                end

                -- LOGIC:
                -- 1. Scan Visible Forward
                -- 2. Scan Physical Forward (Blind Jump)
                -- 3. If Wall -> Reverse -> Repeat 1 & 2
                
                local foundTeam = nil
                local targetTeam = findInDirection(currentIndex, FARM_STATE.Direction, hasCrates)
                
                if targetTeam then
                    -- Found Crate Forward
                    foundTeam = targetTeam
                else
                    -- No Crate Forward -> Look for Base to Scout Forward
                    local scoutTeam = findInDirection(currentIndex, FARM_STATE.Direction, exists)
                    
                    if scoutTeam then
                        -- Found Base to Scout Forward -> BLIND JUMP
                         updateStatus("Transit: " .. scoutTeam) -- AFFICHE LA BASE DE TRANSIT
                         FARM_STATE.LastBase = scoutTeam
                         local nextPos = getSafeScoutPosition(scoutTeam) -- Utilise la position arrière
                         if nextPos then
                             local root = getRoot()
                             if plr then plr:RequestStreamAroundAsync(nextPos.Position) end
                             root.CFrame = nextPos + Vector3.new(0, 3, 0) -- Au sol (Derrière)
                            root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                            root.AssemblyAngularVelocity = Vector3.new(0,0,0)
                             task.wait(2.5)
                             return
                         end
                    else
                         -- WALL HIT (Nothing Forward) -> REVERSE
                         FARM_STATE.Direction = FARM_STATE.Direction * -1
                         updateStatus("Demi-tour !")
                         
                         -- Try New Direction
                         targetTeam = findInDirection(currentIndex, FARM_STATE.Direction, hasCrates)
                         if targetTeam then
                             foundTeam = targetTeam
                         else
                             scoutTeam = findInDirection(currentIndex, FARM_STATE.Direction, exists)
                             if scoutTeam then
                                 -- Blind Jump New Direction
                                 updateStatus("Transit: " .. scoutTeam) -- AFFICHE LA BASE DE TRANSIT
                                 FARM_STATE.LastBase = scoutTeam
                                 local nextPos = getSafeScoutPosition(scoutTeam) -- Utilise la position arrière
                                 if nextPos then
                                     local root = getRoot()
                                     if plr then plr:RequestStreamAroundAsync(nextPos.Position) end
                                     root.CFrame = nextPos + Vector3.new(0, 3, 0) -- Au sol (Derrière)
                                     root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                                     root.AssemblyAngularVelocity = Vector3.new(0,0,0)
                                     task.wait(2.5)
                                     return
                                 end
                             end
                         end
                    end
                end
                
                if foundTeam then
                    updateStatus("Cible Trouvée: " .. foundTeam)
                    FARM_STATE.LastBase = foundTeam -- Mémorise pour le prochain tour
                    
                    -- Trouver une caisse de cette team
                    for _, crate in ipairs(availableCrates) do
                        local owner = crate:GetAttribute("Owner")
                        local p = Players:FindFirstChild(tostring(owner))
                        if p and p.Team and p.Team.Name == foundTeam then
                            targetCrate = crate
                            break
                        end
                    end
                else
                    updateStatus("Aucune autre base trouvée")
                    task.wait(2)
                    return
                end
            end
            
            -- === ÉTAPE 3: VOL DE LA CAISSE ===
            if targetCrate then
                if not isFallback and not isCrateFarming then return end
                
                updateStatus("Vol: " .. (FARM_STATE.LastBase or "Cible"))
                local root = getRoot()
                
                if targetCrate and targetCrate.CFrame then
                    -- TP simple à côté de la caisse
                    if plr then plr:RequestStreamAroundAsync(targetCrate.Position) end
                    root.CFrame = targetCrate.CFrame * CFrame.new(3, 1, 0)
                else
                    return
                end
                
                task.wait(0.5)
                
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                
                -- ATTENTE INTELLIGENTE
                local startTime = tick()
                while targetCrate.Parent and tick() - startTime < 6 do
                    if not targetCrate.Parent then break end 
                    local owner = targetCrate:GetAttribute("Owner")
                    if owner and tostring(owner) == plr.Name then break end
                    task.wait() 
                end
                
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                
                -- === ÉTAPE 4: VENTE & RETOUR ===
                if FARM_CONFIG.SafePosition then
                    updateStatus("Zone Sûre (Cooldown)")
                    root.CFrame = FARM_CONFIG.SafePosition
                    root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    root.AssemblyAngularVelocity = Vector3.new(0,0,0)
                    
                    -- TIMER OVERLAY
                    for i = 12, 1, -1 do
                        if not isCrateFarming then break end
                        updateBigTimer(tostring(i)) 
                        updateStatus("Sécurité: " .. i .. "s")
                        task.wait(1)
                    end
                    updateBigTimer("")
                    
                    if not isCrateFarming then return end
                    
                    updateStatus("Vente...")
                    root.CFrame = FARM_CONFIG.SellPosition
                    root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    root.AssemblyAngularVelocity = Vector3.new(0,0,0)
                    
                    task.wait(1)
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                    task.wait(FARM_CONFIG.SellCrate)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                    task.wait(1.5)
                    
                    -- SI CIBLE UNIQUE: ON DÉSELECTIONNE APRÈS SUCCÈS
                    if FARM_CONFIG.TargetPlayer then
                        -- On mémorise cette base comme la dernière visitée
                        -- pour que le Tour de Map continue depuis ici (vers la droite)
                        local p = Players:FindFirstChild(FARM_CONFIG.TargetPlayer)
                        if p and p.Team then
                            FARM_STATE.LastBase = p.Team.Name
                            updateStatus("Dernière Base: " .. FARM_STATE.LastBase)
                        end
                        
                        -- On désactive le mode manuel pour repasser en auto
                        FARM_CONFIG.TargetPlayer = nil
                        if btnTarget then btnTarget.Text = "🎯" end
                        
                        -- Si la popup est ouverte, on refresh pour enlever la sélection visuelle
                        if PlayerPopup and PlayerPopup.Visible then
                            refreshPlayerList()
                        end
                        task.wait(1)
                    end
                else
                    updateStatus("Err: Pas de Base")
                    task.wait(2)
                end
            else
                updateStatus("Caisse perdue")
                task.wait(1)
            end
        else
            updateStatus("Err: Système Caisses")
        end
    end)
    
    if not success then
        warn("Erreur CrateFarm:", err)
        updateStatus("Erreur interne")
        task.wait(2)
    end
    
    isProcessing = false
    if isCrateFarming then updateStatus("Prêt") else updateStatus("Arrêté") end
end

local function stopAll()
    isFarming = false
    isCrateFarming = false
    isProcessing = false 
    updateStatus("Arrêté")
    updateBigTimer("")
    
    if farmingConnection then farmingConnection:Disconnect() farmingConnection = nil end
    if crateThread then task.cancel(crateThread) crateThread = nil end
end

-- On rend la blacklist accessible globalement et persistante
-- (Désormais gérée par _G.AmadouBlacklistNames et le système de sauvegarde)

local function startAutoFarm()
    if isFarming then return end
    stopAll() 
    isFarming = true
    updateStatus("AutoBuy Actif")
    
    local blacklist = _G.AmadouBlacklistNames -- Utilise la liste globale des NOMS
    local lastTarget = nil
    local lastTargetTime = 0
    local lastCashCollectTime = 0
    local isCollectingCash = false 
    
    farmingConnection = RunService.Heartbeat:Connect(function()
        if not ScreenGui or not ScreenGui.Parent then stopAll() return end
        if not isFarming then 
            if farmingConnection then farmingConnection:Disconnect() farmingConnection = nil end 
            return 
        end
        if isProcessing or isCollectingCash then return end 
        
        local currentMoney = getCurrentCash()
        local tycoon = findPlayerTycoon()
        local now = tick()
        
        if now - lastCashCollectTime > FARM_CONFIG.CashCollectInterval then
            if tycoon then
                local giver = findCashGiver(tycoon)
                if giver then
                    isCollectingCash = true 
                    updateStatus("Collecte Argent...")
                    getRoot().CFrame = giver.CFrame * CFrame.new(4, 2, 0)
                    task.wait(0.2)
                    if firetouchinterest then
                        firetouchinterest(getRoot(), giver, 0)
                        task.wait()
                        firetouchinterest(getRoot(), giver, 1)
                    else
                        local oldPos = getRoot().CFrame
                        getRoot().CFrame = giver.CFrame 
                        task.wait(0.1)
                        getRoot().CFrame = oldPos 
                    end
                    task.wait(0.5)
                    lastCashCollectTime = now 
                    isCollectingCash = false
                    return 
                end
            end
            lastCashCollectTime = now 
        end
        
        -- Plus besoin de nettoyer la blacklist (on stocke des strings persistants)
        
        local buttons = tycoon and tycoon:FindFirstChild("UnpurchasedButtons")
        if currentMoney >= FARM_CONFIG.CashTarget and buttons then
            local targetButton = nil
            for _, btn in ipairs(buttons:GetChildren()) do
                if blacklist[btn.Name] then continue end -- Vérifie le NOM
                if isBuyButton(btn) then targetButton = btn break end
            end
            
            if targetButton then
                updateStatus("Achat: " .. targetButton.Name)
                if targetButton == lastTarget then
                    if now - lastTargetTime > FARM_CONFIG.BlacklistTimeout then
                        blacklist[targetButton.Name] = true -- Bloque le NOM
                        saveBlacklist() -- Sauvegarde immédiate
                        lastTarget = nil
                        return
                    end
                else
                    lastTarget = targetButton
                    lastTargetTime = now
                end
                
                local neon = targetButton:FindFirstChild("Neon") or targetButton:FindFirstChild("Button")
                if neon then
                    getRoot().CFrame = neon.CFrame + Vector3.new(0, 5, 0)
                    task.wait(FARM_CONFIG.TeleportDelay)
                end
            else
                lastTarget = nil
                updateStatus("Recherche...")
            end
        else
            updateStatus("Pas d'argent / Pas de bouton")
        end
    end)
end

local function startCrateFarm()
    if isCrateFarming then return end
    stopAll() 
    isCrateFarming = true
    isProcessing = false 
    storeSellPosition()
    updateStatus("Vol Caisses Actif")
    
    crateThread = task.spawn(function()
        while isCrateFarming do
            if not ScreenGui or not ScreenGui.Parent then isCrateFarming = false break end
            collectAndSellCrate(false)
            task.wait(1)
        end
        crateThread = nil
    end)
end

